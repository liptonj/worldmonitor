# ============================================
# World Monitor Relay Server — Environment Variables
# ============================================
# Copy to .env and fill in values for production deployment
# ============================================

# ------ Supabase (required for orchestrator) ------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ------ Redis (defaults to local container) ------
REDIS_URL=redis://redis:6379

# ------ Logging ------
LOG_LEVEL=info

# ------ gRPC ports (defaults shown) ------
GATEWAY_GRPC_PORT=50051
WORKER_GRPC_PORT=50052
AI_ENGINE_GRPC_PORT=50053

# ------ Service hostnames (Docker service names) ------
GATEWAY_HOST=gateway
WORKER_HOST=worker
AI_ENGINE_HOST=ai-engine

# ------ Gateway HTTP port ------
PORT=3004

# ------ Cloudflare Tunnel (optional) ------
# Only needed if using: ./relay.sh up --tunnel
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ------ Alert Webhook (orchestrator — optional) ------
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ------ Telegram OSINT (ingest-telegram) ------
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash
TELEGRAM_SESSION=your-telegram-session-string
# Channel set to ingest: full | tech | finance (reads from data/telegram-channels.json)
TELEGRAM_CHANNEL_SET=full

# ------ AIS Stream (ais-processor) ------
AISSTREAM_API_KEY=your-aisstream-api-key

# ------ OpenSky (gateway/worker) ------
OPENSKY_CLIENT_ID=your-opensky-client-id
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# ------ AI Engine ------
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OLLAMA_API_URL=https://your-ollama-server/v1/
OLLAMA_MODEL=qwen3:8b
OLLAMA_MAX_TOKENS=1500

# ------ Relay Authentication ------
RELAY_SHARED_SECRET=your-shared-secret
RELAY_AUTH_HEADER=x-relay-key
VITE_WS_RELAY_TOKEN=your-ws-relay-token

# ------ Vercel Callback (relay → Vercel) ------
VERCEL_APP_URL=https://worldmonitor.app

# ------ Admin API (gateway cache endpoints) ------
ADMIN_API_KEY=changeme-generate-a-strong-random-key

# ------ Misc ------
ALLOW_UNAUTHENTICATED_RELAY=false
RELAY_METRICS_WINDOW_SECONDS=60
