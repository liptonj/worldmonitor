# Supabase (required for all services)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Redis (defaults to local container)
REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=info

# gRPC ports (defaults shown)
GATEWAY_GRPC_PORT=50051
WORKER_GRPC_PORT=50052
AI_ENGINE_GRPC_PORT=50053

# Service hostnames (Docker service names)
GATEWAY_HOST=gateway
WORKER_HOST=worker
AI_ENGINE_HOST=ai-engine

# Gateway HTTP port
PORT=3004

# Cloudflare Tunnel (Phase 9)
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# AIS stream (ais-processor)
AISSTREAM_API_KEY=your-aisstream-api-key

# Telegram ingest (ingest-telegram)
TELEGRAM_SESSION=your-telegram-session-string
TELEGRAM_CHANNELS=channel1,channel2,channel3

# Alerting (optional)
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Splunk HEC (production only)
SPLUNK_HEC_URL=https://your-splunk-server:8088
SPLUNK_HEC_TOKEN=your-splunk-hec-token
