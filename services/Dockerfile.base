# Base image for all relay microservices
# Uses @grpc/proto-loader at runtime — no protoc/codegen required
FROM node:22-alpine

# Create non-root app user
RUN addgroup -S relay && adduser -S relay -G relay

WORKDIR /app

# Copy shared library and proto definitions (context: services/)
COPY shared/ /app/shared/
COPY proto/ /app/proto/

# Install shared dependencies (production only)
RUN cd /app/shared && npm install --omit=dev

ENV NODE_ENV=production

USER relay
